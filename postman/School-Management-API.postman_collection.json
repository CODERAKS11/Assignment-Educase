{
  "info": {
    "_postman_id": "4ec58f55-73e2-4cf1-ac95-6bd1e0d2081b",
    "name": "School Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the Node.js school management assignment."
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Quick endpoint to verify that the API is running."
      },
      "response": []
    },
    {
      "name": "Add School",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Green Valley School\",\n  \"address\": \"221B Baker Street, London\",\n  \"latitude\": 28.6139,\n  \"longitude\": 77.209\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/addSchool",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "addSchool"
          ]
        },
        "description": "Adds a new school after validating all required fields."
      },
      "response": []
    },
    {
      "name": "List Schools By Proximity",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/listSchools?latitude=28.6139&longitude=77.209",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "listSchools"
          ],
          "query": [
            {
              "key": "latitude",
              "value": "28.6139"
            },
            {
              "key": "longitude",
              "value": "77.209"
            }
          ]
        },
        "description": "Returns all schools sorted from nearest to farthest using the user's coordinates."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ]
}
